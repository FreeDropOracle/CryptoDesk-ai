{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "types": ["node"],
    "typeRoots": [
      "./.tscheck-tools/node_modules/@types",
      "./node_modules/@types"
    ]
  },
  "include": [
    "tests/unit/main/security/**/*.ts",
    "src/main/security/encryption.ts",
    "src/main/security/keychain.ts",
    "src/main/security/types.ts",
    "src/shared/public/**/*.ts",
    "src/shared/internal/**/*.ts",
    "tests/types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/renderer/**/*",
    "src/main/security/audit-log.ts"
  ]
}
