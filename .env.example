# === APP CONFIG ===
APP_ENV=development
APP_VERSION=1.0.0-alpha.1

# === EXCHANGE API (USER-PROVIDED, NOT HARDCODED) ===
# These are EXAMPLES only - users provide their own keys via UI
# NEVER commit real keys to version control
BINANCE_API_KEY_EXAMPLE=your_binance_api_key_here
BINANCE_SECRET_EXAMPLE=your_binance_secret_here

# === AI CONFIG ===
AI_MODEL_PATH=./assets/models/default-signal-v1.onnx
AI_INFERENCE_TIMEOUT_MS=5000
AI_CONFIDENCE_THRESHOLD=0.65

# === SECURITY ===
ENCRYPTION_ALGORITHM=AES-256-GCM
KEYCHAIN_SERVICE_NAME=cryptodesk-ai
LOG_SENSITIVE_DATA=false

# === TRADING LIMITS ===
MAX_DAILY_LOSS_PERCENT=5
MAX_POSITION_SIZE_PERCENT=20
MIN_CONFIDENCE_FOR_AUTO_ALERT=0.75

# === FEATURE FLAGS ===
ENABLE_TRADING=false
ENABLE_AI_AUTO_EXECUTE=false
ENABLE_CANARY_RELEASE=true
