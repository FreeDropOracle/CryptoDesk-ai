{
  "name": "cryptodesk-ai",
  "version": "1.0.0-alpha.1",
  "description": "AI-Powered Non-Custodial Crypto Trading Desktop App",
  "author": {
    "name": "Ahmed Sami Khedhri",
    "url": "https://github.com/FreeDropOracle"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FreeDropOracle/cryptodesk-ai.git"
  },
  "bugs": {
    "url": "https://github.com/FreeDropOracle/cryptodesk-ai/issues"
  },
  "homepage": "https://github.com/FreeDropOracle/cryptodesk-ai#readme",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:main": "concurrently -k \"tsc --watch\" \"tsc-alias -w\"",
    "dev:renderer": "vite",
    "dev:electron": "node scripts/dev/start-electron.cjs",
    "build:compile": "tsc && tsc-alias",
    "build": "npm run build:compile && vite build && electron-builder",
    "build:win": "npm run build:compile && vite build && electron-builder --win zip",
    "build:win:portable": "npm run build:compile && vite build && electron-builder --win portable",
    "test": "jest",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .ts,.tsx",
    "security:audit": "npm audit && snyk test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tensorflow/tfjs": "4.17.0",
    "better-sqlite3": "9.4.0",
    "ccxt": "4.2.1",
    "electron-log": "5.1.0",
    "electron-safe-storage": "1.0.6",
    "electron-updater": "6.8.3",
    "keytar": "7.9.0",
    "lightweight-charts": "4.1.3",
    "onnxruntime-node": "1.17.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "winston": "3.11.0",
    "zod": "3.22.4",
    "zustand": "4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "1.41.0",
    "@types/better-sqlite3": "7.6.8",
    "@types/jest": "29.5.12",
    "@types/node": "20.11.0",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "@typescript-eslint/eslint-plugin": "6.19.0",
    "@typescript-eslint/parser": "6.19.0",
    "@vitejs/plugin-react": "4.2.1",
    "concurrently": "8.2.0",
    "electron": "28.2.0",
    "electron-builder": "24.9.1",
    "eslint": "8.56.0",
    "jest": "29.7.0",
    "snyk": "1.1284.0",
    "ts-jest": "29.1.2",
    "tsc-alias": "1.8.16",
    "typescript": "5.3.3",
    "vite": "5.0.12",
    "wait-on": "7.2.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  }
}
