{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "outDir": "./dist/renderer",
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "paths": {
      "@renderer/*": ["src/renderer/*"],
      "@shared/public/*": ["src/shared/public/*"]
      // NO ACCESS TO @shared/internal/*
    }
  },
  "include": ["src/renderer/**/*", "src/shared/public/**/*"],
  "exclude": ["src/main/**/*", "src/shared/internal/**/*"]
}
